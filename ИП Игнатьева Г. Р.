<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0c10;
  --bg2:#11141a;
  --bg3:#181c24;
  --bg4:#1e2330;
  --border:#ffffff12;
  --border2:#ffffff20;
  --text:#f0f2f8;
  --text2:#8892a4;
  --text3:#525c6e;
  --accent:#4f8ef7;
  --accent2:#6366f1;
  --green:#22c55e;
  --red:#ef4444;
  --amber:#f59e0b;
  --cyan:#06b6d4;
  --purple:#a855f7;
}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;font-size:14px}

/* HEADER */
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 32px;display:flex;align-items:center;justify-content:space-between;height:64px;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:12px}
.logo-mark{width:36px;height:36px;background:linear-gradient(135deg,#4f8ef7,#6366f1);border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#fff;letter-spacing:.5px}
.logo-text{font-size:15px;font-weight:600;color:var(--text)}
.logo-sub{font-size:12px;color:var(--text2);margin-top:1px}
.header-right{display:flex;align-items:center;gap:16px}
.period-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:6px 14px;font-size:12px;color:var(--text2)}
.period-badge span{color:var(--text);font-weight:500}
.wb-badge{background:#cb11ab18;border:1px solid #cb11ab40;border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;color:#cb11ab}

/* TABS */
.tabs{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 32px;display:flex;gap:4px}
.tab{padding:14px 20px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.tab:hover{color:var(--text)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}

/* CONTENT */
.content{padding:28px 32px;max-width:1400px;margin:0 auto}
.page{display:none}
.page.active{display:block}

/* GRID */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.grid-auto{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:20px}
.card-sm{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px}

/* METRIC CARDS */
.metric{background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent-color,var(--accent))}
.metric-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;font-weight:500}
.metric-value{font-size:28px;font-weight:700;color:var(--text);margin:6px 0 4px;line-height:1}
.metric-sub{font-size:12px;color:var(--text2)}
.metric-delta{display:inline-flex;align-items:center;gap:3px;font-size:12px;font-weight:600;padding:2px 8px;border-radius:20px;margin-top:6px}
.delta-up{background:#22c55e18;color:#22c55e}
.delta-down{background:#ef444418;color:#ef4444}
.delta-neutral{background:#f59e0b18;color:#f59e0b}

/* SECTION TITLES */
.section-title{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.8px;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.section-title::after{content:'';flex:1;height:1px;background:var(--border)}
.block-title{font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px}
.block-sub{font-size:12px;color:var(--text2);margin-bottom:16px}

/* CHART WRAPPER */
.chart-wrap{position:relative;width:100%}

/* ARTICLE TABLE */
.art-table{width:100%;border-collapse:collapse}
.art-table th{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;padding:8px 12px;border-bottom:1px solid var(--border);text-align:left;font-weight:500}
.art-table td{padding:12px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.art-table tr:last-child td{border-bottom:none}
.art-table tr:hover td{background:var(--bg3)}
.art-name{font-weight:500;color:var(--text);font-size:13px;margin-bottom:2px}
.art-category{font-size:11px;color:var(--text3)}
.art-wb{font-size:11px;color:var(--text3);margin-top:1px}
.num{font-weight:600;color:var(--text)}
.num-muted{color:var(--text2);font-size:12px;margin-top:1px}
.rating-stars{display:flex;align-items:center;gap:4px}
.rating-val{font-weight:600;color:var(--text)}
.star{color:#f59e0b;font-size:12px}
.badge-green{background:#22c55e18;color:#22c55e;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:600}
.badge-red{background:#ef444418;color:#ef4444;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:600}
.badge-amber{background:#f59e0b18;color:#f59e0b;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:600}
.badge-blue{background:#4f8ef718;color:#4f8ef7;border-radius:6px;padding:2px 8px;font-size:11px;font-weight:600}

/* PROGRESS BAR */
.prog-wrap{display:flex;align-items:center;gap:10px}
.prog-bar{flex:1;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;background:var(--accent);transition:width .8s ease}
.prog-val{font-size:12px;font-weight:600;color:var(--text);min-width:36px;text-align:right}

/* WAREHOUSE TABLE */
.wh-table{width:100%;border-collapse:collapse}
.wh-table th{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;padding:8px 10px;border-bottom:1px solid var(--border);font-weight:500;text-align:left}
.wh-table td{padding:10px 10px;border-bottom:1px solid var(--border);font-size:13px}
.wh-table tr:last-child td{border-bottom:none}
.wh-table tr:hover td{background:var(--bg3)}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:6px}
.dot-green{background:#22c55e}
.dot-amber{background:#f59e0b}
.dot-red{background:#ef4444}

/* GEO BARS */
.geo-item{margin-bottom:14px}
.geo-name{font-size:12px;color:var(--text2);margin-bottom:5px;display:flex;justify-content:space-between}
.geo-name span{font-weight:600;color:var(--text)}

/* FUNNEL VIZ */
.funnel-step{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:8px;position:relative}
.funnel-arrow{color:var(--text3);font-size:16px;text-align:center;margin:2px 0}
.funnel-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.funnel-data{flex:1}
.funnel-name{font-size:12px;color:var(--text2)}
.funnel-val{font-size:20px;font-weight:700;color:var(--text)}
.funnel-conv{font-size:11px;color:var(--text3);margin-top:1px}
.funnel-bar-wrap{width:100px;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden;flex-shrink:0}
.funnel-bar-fill{height:100%;background:var(--accent);transition:width 1s ease}

/* ALERT CARDS */
.alert{border-radius:12px;padding:14px 16px;display:flex;gap:12px;align-items:flex-start;margin-bottom:10px}
.alert-icon{font-size:18px;flex-shrink:0;margin-top:1px}
.alert-title{font-size:13px;font-weight:600;margin-bottom:2px}
.alert-body{font-size:12px;line-height:1.5}
.alert-warn{background:#f59e0b10;border:1px solid #f59e0b30}
.alert-warn .alert-title{color:#f59e0b}
.alert-warn .alert-body{color:#f59e0b99}
.alert-danger{background:#ef444410;border:1px solid #ef444430}
.alert-danger .alert-title{color:#ef4444}
.alert-danger .alert-body{color:#ef444499}
.alert-success{background:#22c55e10;border:1px solid #22c55e30}
.alert-success .alert-title{color:#22c55e}
.alert-success .alert-body{color:#22c55e99}
.alert-info{background:#4f8ef710;border:1px solid #4f8ef730}
.alert-info .alert-title{color:#4f8ef7}
.alert-info .alert-body{color:#4f8ef799}

/* SCORE RING */
.score-ring-wrap{display:flex;align-items:center;gap:20px}
.score-ring{position:relative;width:90px;height:90px}
.score-ring svg{transform:rotate(-90deg)}
.score-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.score-center .val{font-size:20px;font-weight:700;color:var(--text)}
.score-center .lbl{font-size:9px;color:var(--text3);text-transform:uppercase}

/* MINI SPARKLINE */
.sparkline-row{display:flex;align-items:center;gap:10px}

/* SEPARATOR */
.sep{height:1px;background:var(--border);margin:20px 0}

/* FOOTER */
.footer{text-align:center;padding:32px;color:var(--text3);font-size:11px;border-top:1px solid var(--border);margin-top:40px}
.footer strong{color:var(--accent)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.page.active .card,.page.active .metric,.page.active .art-table,.page.active .alert{animation:fadeUp .35s ease both}
.page.active .card:nth-child(2){animation-delay:.05s}
.page.active .card:nth-child(3){animation-delay:.1s}
.page.active .card:nth-child(4){animation-delay:.15s}
.page.active .metric:nth-child(2){animation-delay:.04s}
.page.active .metric:nth-child(3){animation-delay:.08s}
.page.active .metric:nth-child(4){animation-delay:.12s}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
</style>
</head>
